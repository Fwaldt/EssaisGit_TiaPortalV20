  <NewLine UId="40" />
  <Blank Num="4" UId="41" />
  <LineComment UId="42">
    <Text UId="43"> Comment/Function: This function manages alarms and warnings based on a  </Text>
  </LineComment>
  <NewLine UId="44" />
  <Blank Num="4" UId="45" />
  <LineComment UId="46">
    <Text UId="47">                   current value compared to predefined target. After an</Text>
  </LineComment>
  <NewLine UId="48" />
  <Blank Num="4" UId="49" />
  <LineComment UId="50">
    <Text UId="51">                   initial delay, it activates specific alarms OR warnings if the</Text>
  </LineComment>
  <NewLine UId="52" />
  <Blank Num="4" UId="53" />
  <LineComment UId="54">
    <Text UId="55">                   value exceeds thresholds, and can also trigger machine</Text>
  </LineComment>
  <NewLine UId="56" />
  <Blank Num="4" UId="57" />
  <LineComment UId="58">
    <Text UId="59">                   shutdown or signal a defective part according TO conditions</Text>
  </LineComment>
  <NewLine UId="60" />
  <Blank Num="4" UId="61" />
  <LineComment UId="62">
    <Text UId="63">                   configured on the HMI.</Text>
